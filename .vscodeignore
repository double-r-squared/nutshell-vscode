.vscode/**
**/*.map
.git/**
.github/**
.gitignore
.nutshell-server.log
.nutshell-server.pid
.nutshell-api-key
.nutshell-docs-root/**
**/*.log
*.vsix
memory/**

# Internal docs — for contributors / agents, not for the public listing.
AGENTS.md
CLAUDE.md
docs/**

# Dev scripts (the reload helper; users get the published flow)
scripts/**

# node_modules: exclude everything by default, then re-include the
# runtime deps the extension needs at execution time.
node_modules/**
!node_modules/anymatch/**
!node_modules/binary-extensions/**
!node_modules/braces/**
!node_modules/chokidar/**
!node_modules/fill-range/**
!node_modules/glob-parent/**
!node_modules/is-binary-path/**
!node_modules/is-extglob/**
!node_modules/is-glob/**
!node_modules/is-number/**
!node_modules/normalize-path/**
!node_modules/picomatch/**
!node_modules/readdirp/**
!node_modules/to-regex-range/**
